<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IA Bio-Strategist"
            android:textColor="#BB86FC"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- هادي هي الـ ProgressBar لي كاتدور ف وقت التحميل -->
        <ProgressBar
            android:id="@+id/pbLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="5dp"
            android:text="Cliquez sur le bouton pour générer votre stratégie..." />

        <!-- زر توليد النصائح -->
        <Button
            android:id="@+id/btnGenerateAi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Générer ma stratégie du jour"
            android:layout_marginTop="30dp"
            android:backgroundTint="#03DAC5"
            android:textColor="#000000"
            android:textStyle="bold"/>

        <!-- زر الرجوع للبروفايل (الجديد) -->
        <Button
            android:id="@+id/btnBackFromAi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="RETOUR AU PROFIL"
            android:layout_marginTop="12dp"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>