<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Bio-Strategist"
            android:textColor="#BB86FC"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Progress bar shown during loading -->
        <ProgressBar
            android:id="@+id/pbLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="5dp"
            android:text="Click the button to generate your strategy..." />

        <!-- Button to generate advice -->
        <Button
            android:id="@+id/btnGenerateAi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Generate my strategy for the day"
            android:layout_marginTop="30dp"
            android:backgroundTint="#03DAC5"
            android:textColor="#000000"
            android:textStyle="bold"/>

        <!-- Button to go back to profile -->
        <Button
            android:id="@+id/btnBackFromAi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="BACK TO PROFILE"
            android:layout_marginTop="12dp"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>