<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Fitness Profile"
            android:textColor="#BB86FC"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <!-- Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Full Name" android:textColor="#BDBDBD" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etProfileName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Age -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Age" android:textColor="#BDBDBD" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etProfileAge"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Goal -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Weekly Goal (minutes)" android:textColor="#BDBDBD" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etProfileGoal"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="#000000"
            android:layout_marginBottom="32dp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SAVE CHANGES"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C4DFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- AI Button -->
        <Button
            android:id="@+id/btnGoToAi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="AI STRATEGY (COACH)"
            android:textColor="#000000"
            android:backgroundTint="#03DAC5"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>