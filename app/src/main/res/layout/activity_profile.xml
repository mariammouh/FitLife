<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon Profil Fitness"
            android:textColor="#BB86FC"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <!-- Nom -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nom complet" android:textColor="#BDBDBD" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etProfileName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Âge -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Âge" android:textColor="#BDBDBD" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etProfileAge"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Objectif -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Objectif hebdomadaire (minutes)" android:textColor="#BDBDBD" android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etProfileGoal"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="#000000"
            android:layout_marginBottom="32dp"/>

        <!-- زر حفظ التعديلات -->
        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ENREGISTRER"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C4DFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- زر الذكاء الاصطناعي (الجديد) -->
        <Button
            android:id="@+id/btnGoToAi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="STRATÉGIE IA (CONSEILLER)"
            android:textColor="#000000"
            android:backgroundTint="#03DAC5"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>