<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- ── TOP BAR ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:src="@drawable/ic_baseline_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Settings"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- ══════════════════════════════════════ -->
        <!-- SECTION 1 — PERSONALISATION           -->
        <!-- ══════════════════════════════════════ -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERSONALISATION"
            android:textColor="@color/purple_200"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Username -->
                <RelativeLayout
                    android:id="@+id/rowUsername"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icUsername"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/baseline_person_24"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icUsername"
                        android:layout_marginStart="12dp"
                        android:text="Username"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="jane_doe"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_baseline_chevron_right_24"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A3E" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Weight Goal -->
                <RelativeLayout
                    android:id="@+id/rowWeightGoal"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icWeight"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_workouts"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icWeight"
                        android:layout_marginStart="12dp"
                        android:text="Target Weight"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvWeightGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— kg"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_baseline_chevron_right_24"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A3E" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Fitness Goal -->
                <RelativeLayout
                    android:id="@+id/rowFitnessGoal"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icGoal"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_burned"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icGoal"
                        android:layout_marginStart="12dp"
                        android:text="Fitness Goal"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvFitnessGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lose Weight"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_baseline_chevron_right_24"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A3E" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Language -->
                <RelativeLayout
                    android:id="@+id/rowLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icLanguage"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/baseline_info_24"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icLanguage"
                        android:layout_marginStart="12dp"
                        android:text="Language"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvLanguage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Français"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_baseline_chevron_right_24"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                </RelativeLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!-- SECTION 2 — PREMIUM UPGRADE           -->
        <!-- ══════════════════════════════════════ -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUBSCRIPTION"
            android:textColor="@color/purple_200"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <!-- Free trials remaining -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/icTries"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_workouts"
                    app:tint="@color/purple_200" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/icTries"
                    android:layout_marginStart="12dp"
                    android:text="Free trials remaining"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvNbrTries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="— / 10"
                    android:textColor="@color/purple_200"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <!-- Upgrade to Premium card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUpgrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚀 FitLife Premium"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unlock unlimited access"
                            android:textColor="#9B6FF9"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="€9.99"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/mo"
                            android:textColor="#7A7A9A"
                            android:textSize="13sp"
                            android:layout_marginStart="3dp" />
                    </LinearLayout>

                </RelativeLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#2A2A3E"
                    android:layout_marginVertical="14dp" />

                <!-- Feature bullets -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦  Unlimited workout sessions"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦  Full statistics &amp; charts"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦  Advanced progress tracking"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦  Priority access to new features"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#2A2A3E"
                    android:layout_marginVertical="14dp" />

                <!-- Upgrade button -->
                <TextView
                    android:id="@+id/btnUpgradeNow"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="Upgrade Now"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/blue_border_white_back_rounded"
                    android:backgroundTint="@color/accent_purple" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!-- SECTION 3 — DAILY REMINDER            -->
        <!-- ══════════════════════════════════════ -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAILY REMINDER"
            android:textColor="@color/purple_200"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Enable reminder toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:id="@+id/icReminder"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/baseline_notifications_24"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icReminder"
                        android:layout_marginStart="12dp"
                        android:text="Enable reminder"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchReminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/accent_purple" />

                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A3E" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Time picker row -->
                <RelativeLayout
                    android:id="@+id/rowReminderTime"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icTime"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_time"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icTime"
                        android:layout_marginStart="12dp"
                        android:text="Reminder time"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvReminderTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="08:00"
                            android:textColor="@color/purple_200"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_baseline_chevron_right_24"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A3E" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Reminder message -->
                <RelativeLayout
                    android:id="@+id/rowReminderMessage"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icMsg"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/baseline_notifications_24"
                        app:tint="@color/purple_200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icMsg"
                        android:layout_marginStart="12dp"
                        android:text="Reminder message"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvReminderMsg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time for your workout!"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:maxWidth="140dp"
                            android:ellipsize="end"
                            android:singleLine="true" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_baseline_chevron_right_24"
                            app:tint="@color/text_secondary" />

                    </LinearLayout>

                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A3E" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <!-- Test notification row -->
                <RelativeLayout
                    android:id="@+id/rowTestNotif"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/icTestNotif"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/baseline_notifications_24"
                        app:tint="#9B6FF9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icTestNotif"
                        android:layout_marginStart="12dp"
                        android:text="Send test notification"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_baseline_chevron_right_24"
                        app:tint="@color/text_secondary" />

                </RelativeLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── LOGOUT BUTTON ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:id="@+id/rowLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/icLogout"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/baseline_logout_24"
                    app:tint="#FF4444" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/icLogout"
                    android:layout_marginStart="12dp"
                    android:text="Log Out"
                    android:textColor="#FF4444"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>