<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Use MaterialComponents theme to support TextInputLayout and other Material views -->
    <style name="Theme.Fitlife" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Base application theme -->
        <!-- Dark status bar -->
        <item name="android:statusBarColor">@android:color/black</item>
        <!-- White icons in status bar -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Standard Material Colors -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@android:color/black</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Base.Theme.FitLife" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_200</item>
    </style>

    <style name="Theme.FitLife" parent="Base.Theme.FitLife"/>
</resources>
